# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — your real keys never end up in the repo.
# This file (`.env.example`) IS committed — never put real keys here.
#
# Used by:
#   * run_eval.py            (auto-loads via python-dotenv)
#   * examples/*.py          (auto-loads via python-dotenv)
#
# A real shell `export` overrides whatever is in this file, so CI can keep
# using its own secrets mechanism without conflicts.

# Required for `--llm openai` and the production-style examples.
OPENAI_API_KEY=

# Required for any real eval run (anything except `--llm mock` without a key).
TTC_API_KEY=
